{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@database/*": ["database/*"]
    }
  },
  "include": ["electron.vite.config.*", "electron/**/*", "database/**/*"]
}
